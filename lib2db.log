# -------------------------
# 6) Get loaded libraries
# -------------------------
set libs [get_libs *]
{"NangateOpenCellLibrary"}
if { [llength $libs] == 0 } {
  puts "\nERROR: No libraries loaded from: $lib_file\n"
  exit 1
}
# -------------------------
# 7) Write .db for each lib
# -------------------------
foreach lib $libs {
  set out_file "$out_dir/${lib}.db"
  puts "INFO: Writing DB: $out_file"
  write_lib -format db -output $out_file $lib
}
